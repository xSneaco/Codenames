# ===========================================
# Codenames Application Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# -----------------
# Database Settings
# -----------------
POSTGRES_USER=codenames
POSTGRES_PASSWORD=codenames_password
POSTGRES_DB=codenames
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_URL=postgresql://codenames:codenames_password@postgres:5432/codenames

# -----------------
# Backend Settings
# -----------------
NODE_ENV=development
PORT=3001

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# -----------------
# Frontend Settings
# -----------------
# API URL for frontend to connect to backend
VITE_API_URL=http://localhost:3001

# WebSocket URL for real-time communication
VITE_WS_URL=ws://localhost:3001

# -----------------
# Docker Settings
# -----------------
COMPOSE_PROJECT_NAME=codenames
